# DirektDSP_GUI — clang-format style
# Follows JUCE coding standards:
#   https://juce.com/develop/coding-standards/
# Key JUCE conventions encoded here:
#   - 4-space indent, no tabs
#   - Allman braces (opening brace on its own line)
#   - Space before '(' whenever the parentheses are non-empty
#   - 120-column limit
#   - Pointer/reference qualifiers attached to the type (left)
#   - Includes grouped: JUCE modules → system → project
---
Language:        Cpp
BasedOnStyle:    LLVM

# ── Indentation ───────────────────────────────────────────────────────────────
IndentWidth:                     4
TabWidth:                        4
UseTab:                          Never
ContinuationIndentWidth:         4
IndentCaseLabels:                true
IndentPPDirectives:              BeforeHash
ConstructorInitializerIndentWidth: 4

# ── Column limit ──────────────────────────────────────────────────────────────
ColumnLimit:                     120

# ── Braces (Allman / next-line style throughout) ──────────────────────────────
BreakBeforeBraces:               Allman

# ── Spacing — JUCE's distinctive space before non-empty '(' ──────────────────
# Produces: `foo (args)` and `if (cond)` but `foo()` with no space.
SpaceBeforeParens:               NonEmptyParentheses
SpaceInEmptyParentheses:         false
SpaceAfterCStyleCast:            false
SpaceBeforeAssignmentOperators:  true
SpaceBeforeSquareBrackets:       false
SpacesInAngles:                  Never
SpacesInContainerLiterals:       false

# ── Namespaces ────────────────────────────────────────────────────────────────
NamespaceIndentation:            None
CompactNamespaces:               false

# ── Includes ──────────────────────────────────────────────────────────────────
SortIncludes:                    CaseSensitive
IncludeBlocks:                   Regroup
IncludeCategories:
  # 1. JUCE module headers
  - Regex:    '^<juce_'
    Priority: 1
  # 2. System / standard-library headers
  - Regex:    '^<'
    Priority: 2
  # 3. Project headers
  - Regex:    '.*'
    Priority: 3

# ── Alignment ─────────────────────────────────────────────────────────────────
AlignConsecutiveAssignments:     false
AlignConsecutiveDeclarations:    false
AlignTrailingComments:           true

# ── Line-break rules ──────────────────────────────────────────────────────────
AllowShortFunctionsOnASingleLine:    Inline
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine:        false
AllowShortCaseLabelsOnASingleLine:   false
BreakConstructorInitializers:        BeforeColon

# ── Pointer / reference alignment (attached to type, not name) ────────────────
PointerAlignment:                Left
ReferenceAlignment:              Left

# ── Access modifiers ──────────────────────────────────────────────────────────
AccessModifierOffset:            -4

# ── Penalty tweaks ────────────────────────────────────────────────────────────
PenaltyBreakBeforeFirstCallParameter: 150
PenaltyReturnTypeOnItsOwnLine:        200
